# ========== SERVIDOR ==========
PORT=8080

# ========== BANCO DE DADOS ==========
DB_USER=postgres
DB_PASSWORD=seu_password_aqui
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kuvia_db

# ========== FRONTEND ==========
FRONTEND_URL=http://localhost:5173

# ========== JWT ==========
JWT_SECRET=sua_chave_secreta_super_segura_aqui_com_muitos_caracteres

# Tempo de expiração do JWT (ex: 7d, 24h)
JWT_EXPIRES_IN=7d

# ========== CLOUDINARY ==========
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========== ADMIN (opcional, usado pelo seed) ==========
